pkgbase = p2record-git
	pkgdesc = Linux game clip recorder — GTK4 + FFmpeg ring buffer, Wayland/X11, VAAPI
	pkgver = 0.2.0
	pkgrel = 1
	url = https://github.com/Varionetzwerk/p2record
	install = p2record.install
	arch = any
	license = MIT
	depends = python
	depends = python-gobject
	depends = gtk4
	depends = libadwaita
	depends = ffmpeg
	depends = python-evdev
	depends = python-xlib
	depends = python-dbus
	depends = gstreamer
	depends = gst-plugins-base
	depends = gst-plugin-pipewire
	optdepends = xdg-desktop-portal: Wayland screen capture (required on Wayland)
	optdepends = xdg-desktop-portal-gnome: GNOME Wayland support
	optdepends = xdg-desktop-portal-kde: KDE Wayland support
	optdepends = xdg-desktop-portal-wlr: Sway/Hyprland Wayland support
	optdepends = libayatana-appindicator: System tray icon
	optdepends = pipewire-pulse: Desktop audio + microphone recording
	optdepends = pulseaudio: Desktop audio + microphone recording (alternative)
	provides = p2record
	conflicts = p2record
	source = git+https://github.com/Varionetzwerk/p2record.git
	sha256sums = SKIP

pkgname = p2record-git
